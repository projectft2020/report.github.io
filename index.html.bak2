            <button class="filter-btn" onclick="filterReports('quant-evolve')">QuantEvolve</button>
            <button class="filter-btn" onclick="filterReports('momentum')">動能策略</button>
            <button class="filter-btn" onclick="filterReports('system')">系統優化</button>
        </div>

        <div class="timeline" id="timeline">
            <!-- Reports will be loaded here -->
        </div>

        <div class="footer">
            <p>© 2026 Charlie's Quantitative Trading Research Hub</p>
