# Scout Reports Environment Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Application
# =============================================================================
APP_NAME=Scout Reports API
APP_VERSION=1.0.0
DEBUG=True

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8001

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./scout_reports.db
# For PostgreSQL: postgresql://user:password@localhost/dbname
# For MySQL: mysql+pymysql://user:password@localhost/dbname

# =============================================================================
# Scout Data
# =============================================================================
SCOUT_REPORTS_DIR=/app/scout_projects
SCOUT_CONFIG_PATH=/app/scout_config/PREFERENCES_v2.json

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["http://localhost:5174", "http://localhost:5175"]

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/backend.log
LOG_FILE_MAX_SIZE=10 MB
LOG_FILE_BACKUP_COUNT=7

# =============================================================================
# Security
# =============================================================================
# Authentication (planned for Phase 2)
# SECRET_KEY=your-secret-key-here
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# Cache
# =============================================================================
# Redis (optional, for production)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL=300  # seconds

# =============================================================================
# External Services (optional)
# =============================================================================
# NLP service for topic extraction
# NLP_SERVICE_URL=http://localhost:8002

# Email notifications (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=Scout Reports <noreply@example.com>

# =============================================================================
# Frontend (Vite)
# =============================================================================
VITE_API_URL=http://localhost:8001
VITE_NODE_ENV=development
VITE_MODE=development

# =============================================================================
# Testing
# =============================================================================
TEST_DATABASE_URL=sqlite:///./test_scout_reports.db
