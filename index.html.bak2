        function renderReports(filter = 'all') {
            const timeline = document.getElementById('timeline');
            const filteredReports = filter === 'all' 
                ? reports 
                : reports.filter(r => r.category === filter);

            if (filteredReports.length === 0) {
                timeline.innerHTML = `
                    <div class="empty-state">
                        <p>🔍 沒有找到符合篩選條件的報告</p>
                    </div>
                `;
                return;
            }

            timeline.innerHTML = filteredReports.map(report => `
                <div class="report-card ${report.category}" onclick="window.location.href='${report.file}'">
                    <div class="report-header">
                        <h3 class="report-title">${report.title}</h3>
                        <span class="report-date">📅 ${report.date}${report.time ? " " + report.time : ""}</span>
                    </div>
                    <div class="report-tags">
                        ${report.tags.map(tag => `<span class="tag ${report.category}">${tag}</span>`).join('')}
                    </div>
                    <p class="report-description">${report.description}</p>
                    <div class="report-meta">
                        <span>📁 ${report.category}</span>
                        <span>📄 ${report.id}</span>
                    </div>
                    <a href="${report.file}" class="read-more" onclick="event.stopPropagation()">
                        閱讀完整報告 →
                    </a>
                </div>
            `).join('');
        }

        function filterReports(category) {
            // Update button states
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.textContent === getCategoryName(category)) {
                    btn.classList.add('active');
                }
            });

            renderReports(category);
        }

        function getCategoryName(category) {
            const names = {
                'all': '全部',
                'trend-trading': '趨勢交易',
                'quant-evolve': 'QuantEvolve',
                'momentum': '動能策略',
                'system': '系統優化'
            };
            return names[category] || category;
        }

        // Initial render
        renderReports('all');
    </script>
</body>
