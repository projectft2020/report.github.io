{
  "daemon": {
    "name": "auto_improve",
    "version": "1.0.0",
    "description": "自動改進守護進程 - 每天凌晨自動執行自我改進",
    "enabled": true,
    "schedule": {
      "cron": "0 2 * * *",
      "timezone": "Asia/Taipei",
      "description": "每天凌晨 2 點執行"
    }
  },
  "improvement": {
    "max_per_day": 1,
    "min_hours_between": 24,
    "analysis_window_hours": 24,
    "priority_order": [
      "fix_error",
      "record_insight",
      "optimize_workflow",
      "update_documentation"
    ]
  },
  "targets": {
    "memory_files": [
      "MEMORY.md",
      "SOUL.md",
      "memory/topics/*.md"
    ],
    "skill_files": [
      "skills/*/SKILL.md"
    ],
    "system_files": [
      "kanban-ops/*.py",
      "tasks.json"
    ]
  },
  "logging": {
    "file": "memory/improvements.log",
    "format": "markdown",
    "include_full_analysis": false
  }
}
